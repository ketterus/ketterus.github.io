<nav class="topbar">
  <div class="site-shell">
    <div class="topbar-inner">
      <a class="brand" href="/" aria-label="{{ site.name }}">
        <span class="brand-text">{{ site.name }}</span>
      </a>

      <div class="topbar-actions">
        {% if headerMode == "portalHome" %}
          <a href="/portal/portal-service-request/" class="btn btn-brand" id="projectCenterServiceRequestLink">Submit Service Request</a>
          {% if showPortalMenuButton %}
            <a href="/portal/menu/" class="btn btn-menu" id="projectCenterMenuLink">Menu</a>
          {% endif %}

        {% elif headerMode == "portalInner" %}
          <a href="/portal/portal-service-request/" class="btn btn-brand" id="projectCenterServiceRequestLink">Submit Service Request</a>
          <a href="/portal/v2/" class="btn btn-outline-brand" id="projectCenterBackLink">Back to Projects</a>
          {% if showPortalMenuButton %}
            <a href="/portal/menu/" class="btn btn-menu" id="projectCenterMenuLink">Menu</a>
          {% endif %}

        {% elif headerMode == "portalSignedOut" %}
          <a href="/portal/v2/sign-in/" class="btn btn-outline-brand">Project Center Sign In</a>
          {% if showPublicMenuButton %}
            <a href="{{ site.menu_url }}" class="btn btn-menu">Menu</a>
          {% endif %}

        {% else %}
          <a href="{{ site.cta_url }}" class="btn btn-brand">{{ site.cta_label }}</a>
          <a href="/portal/v2/sign-in/" class="btn btn-outline-brand">{{ site.project_center_label }}</a>
          <a href="{{ site.menu_url }}" class="btn btn-menu">Menu</a>
        {% endif %}
      </div>
    </div>
  </div>
</nav>

{% if headerMode == "portalHome" or headerMode == "portalInner" %}
<script>
  (function () {
    const params = new URLSearchParams(window.location.search);
    const token = (params.get("t") || "").trim();

    const backLink = document.getElementById("projectCenterBackLink");
    const serviceLink = document.getElementById("projectCenterServiceRequestLink");
    const menuLink = document.getElementById("projectCenterMenuLink");

    if (backLink) {
      backLink.href = token ? "/portal/v2/?t=" + encodeURIComponent(token) : "/portal/";
    }

    if (serviceLink) {
      serviceLink.href = token
        ? "/portal/portal-service-request/?t=" + encodeURIComponent(token)
        : "/portal/portal-service-request/";
    }

    if (menuLink) {
      menuLink.href = token
        ? "/portal/menu/?t=" + encodeURIComponent(token)
        : "/portal/menu/";
    }
  })();
</script>
{% endif %}