<nav class="topbar">
  <div class="site-shell">
    <div class="topbar-inner">
      <a class="brand" href="/" aria-label="{{ site.name }}">
        <span class="brand-text">{{ site.name }}</span>
      </a>

      <div class="topbar-actions">
        {% if projectCenterHeader %}
          <a href="/portal/" class="btn btn-outline-brand">Back to Projects</a>
        {% else %}
          <a href="{{ site.cta_url }}" class="btn btn-brand">{{ site.cta_label }}</a>
          <a href="/portal/sign-in/" class="btn btn-outline-brand">{{ site.project_center_label }}</a>
          <a href="{{ site.menu_url }}" class="btn btn-menu">Menu</a>
        {% endif %}
      </div>
    </div>
  </div>
</nav>