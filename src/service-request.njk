---
layout: layouts/base.njk
title: Ketter Home Improvements | Service Request
permalink: /service-request.html
---

<main class="page-wrap">
  <div class="content-shell">
    <div class="card page-card">
      <div class="card-body p-4 p-md-5">
        <div class="mb-4">
          <h1 class="h2 mb-2">Request Service</h1>
          <p class="text-muted mb-0">Send the job details and we will review your request as quickly as possible.</p>
        </div>

        <div id="formMessage" class="alert d-none" role="alert"></div>

        <form
          id="serviceRequestForm"
          action="https://script.google.com/macros/s/AKfycbyKZJythlKKWbaT57pIJYmj69kvAedP31TtUXErr4nsuchx3aHzh5t75PukLWs-Kjg9aw/exec"
          method="post"
          novalidate
        >
          <input type="hidden" id="RequesterAddress" name="RequesterAddress">
          <input type="hidden" id="ServiceAddress" name="ServiceAddress">
          <input type="hidden" id="BillingAddress" name="BillingAddress">

          <div class="row g-3">
            <div class="col-12">
              <h2 class="h5 mb-1">Requester Information</h2>
              <p class="text-muted small mb-0">This is the person submitting the service request.</p>
            </div>

            <div class="col-md-6">
              <label class="form-label required" for="RequesterName">Full Name</label>
              <input class="form-control" id="RequesterName" name="RequesterName" autocomplete="name" required>
              <div class="invalid-feedback">Please enter your full name.</div>
            </div>

            <div class="col-md-6">
              <label class="form-label required" for="RequesterRelationship">Relationship to Property</label>
              <select class="form-select" id="RequesterRelationship" name="RequesterRelationship" required>
                <option value="">Select...</option>
                <option value="Owner">Owner</option>
                <option value="Tenant">Tenant</option>
                <option value="Property Manager">Property Manager</option>
                <option value="Family Member">Family Member</option>
                <option value="Agent">Agent</option>
                <option value="Other">Other</option>
              </select>
              <div class="invalid-feedback">Please select your relationship to the property.</div>
            </div>

            <div class="col-md-6">
              <label class="form-label required" for="RequesterEmail">Email</label>
              <input class="form-control" id="RequesterEmail" name="RequesterEmail" type="email" autocomplete="email" required>
              <div class="invalid-feedback">Enter a valid email address.</div>
            </div>

            <div class="col-md-6">
              <label class="form-label required" for="RequesterPhone">Phone</label>
              <input
                class="form-control phone-input"
                id="RequesterPhone"
                name="RequesterPhone"
                type="tel"
                inputmode="numeric"
                autocomplete="tel"
                maxlength="14"
                placeholder="3045551212"
                required
              >
              <div class="form-text">US numbers only. Include area code.</div>
              <div class="invalid-feedback">Enter a valid 10-digit US phone number.</div>
            </div>

            <div class="col-md-4">
              <label class="form-label required" for="TextOK">Text OK</label>
              <select class="form-select" id="TextOK" name="TextOK" required>
                <option value="">Select...</option>
                <option value="Yes">Yes</option>
                <option value="No">No</option>
              </select>
              <div class="invalid-feedback">Please select Yes or No.</div>
            </div>

            <div class="col-12 pt-2">
              <h3 class="h6 mb-1">Requester Address</h3>
              <p class="text-muted small mb-0">This is your mailing or home address.</p>
            </div>

            <div class="col-md-8">
              <label class="form-label required" for="RequesterStreet1">Street Address</label>
              <input class="form-control" id="RequesterStreet1" name="RequesterStreet1" autocomplete="address-line1" required>
              <div class="invalid-feedback">Please enter your street address.</div>
            </div>

            <div class="col-md-4">
              <label class="form-label" for="RequesterStreet2">Address Line 2</label>
              <input class="form-control" id="RequesterStreet2" name="RequesterStreet2" autocomplete="address-line2">
            </div>

            <div class="col-md-5">
              <label class="form-label required" for="RequesterCity">City</label>
              <input class="form-control" id="RequesterCity" name="RequesterCity" autocomplete="address-level2" required>
              <div class="invalid-feedback">Please enter your city.</div>
            </div>

            <div class="col-md-3">
              <label class="form-label required" for="RequesterState">State</label>
              <input class="form-control text-uppercase" id="RequesterState" name="RequesterState" maxlength="2" autocomplete="address-level1" required>
              <div class="invalid-feedback">Enter the 2-letter state code.</div>
            </div>

            <div class="col-md-4">
              <label class="form-label required" for="RequesterZip">ZIP</label>
              <input class="form-control zip-input" id="RequesterZip" name="RequesterZip" inputmode="numeric" maxlength="5" autocomplete="postal-code" required>
              <div class="invalid-feedback">Enter a 5-digit ZIP code.</div>
            </div>

            <div class="col-12 pt-4">
              <h2 class="h5 mb-1">Service Details</h2>
              <p class="text-muted small mb-0">Tell us what needs attention and where the work is located.</p>
            </div>

            <div class="col-md-4">
              <label class="form-label required" for="Urgency">Urgency</label>
              <select class="form-select" id="Urgency" name="Urgency" required>
                <option value="">Select...</option>
                <option value="Routine">Routine</option>
                <option value="Soon">Soon</option>
                <option value="Urgent">Urgent</option>
              </select>
              <div class="invalid-feedback">Please select urgency.</div>
            </div>

            <div class="col-md-4">
              <label class="form-label required" for="BestContactTime">Best Contact Time</label>
              <select class="form-select" id="BestContactTime" name="BestContactTime" required>
                <option value="">Select...</option>
                <option value="8 AM - 12 PM">8 AM - 12 PM</option>
                <option value="12 PM - 4 PM">12 PM - 4 PM</option>
                <option value="4 PM - 8 PM">4 PM - 8 PM</option>
                <option value="Anytime">Anytime</option>
              </select>
              <div class="invalid-feedback">Please select the best contact time.</div>
            </div>

            <div class="col-md-4">
              <label class="form-label required" for="ServiceType">Service Type</label>
              <select class="form-select" id="ServiceType" name="ServiceType" required>
                <option value="">Select service...</option>
                <option value="General Repair">General Repair</option>
                <option value="Property Maintenance">Property Maintenance</option>
                <option value="Installations">Installations</option>
                <option value="Interior Improvements">Interior Improvements</option>
                <option value="Rental Turnover Work">Rental Turnover Work</option>
                <option value="Custom Request">Custom Request</option>
              </select>
              <div class="invalid-feedback">Please select a service type.</div>
            </div>

            <div class="col-md-6">
              <label class="form-label required" for="PropertyOccupied">Property Occupied</label>
              <select class="form-select" id="PropertyOccupied" name="PropertyOccupied" required>
                <option value="">Select...</option>
                <option value="Yes">Yes</option>
                <option value="No">No</option>
                <option value="Unknown">Unknown</option>
              </select>
              <div class="invalid-feedback">Please select property occupied status.</div>
            </div>

            <div class="col-md-6">
              <label class="form-label required" for="PermissionToEnter">Permission to Enter</label>
              <select class="form-select" id="PermissionToEnter" name="PermissionToEnter" required>
                <option value="">Select...</option>
                <option value="Yes">Yes</option>
                <option value="No">No</option>
                <option value="Call First">Call First</option>
              </select>
              <div class="invalid-feedback">Please select permission to enter.</div>
            </div>

            <div class="col-12">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" id="ServiceSameAsRequester" name="ServiceSameAsRequester" value="Yes">
                <label class="form-check-label" for="ServiceSameAsRequester">
                  Service address is same as my address
                </label>
              </div>
            </div>

            <div id="serviceAddressFields" class="row g-3">
              <div class="col-12 pt-2">
                <h3 class="h6 mb-1">Service Address</h3>
                <p class="text-muted small mb-0">This is the property address where the work is needed.</p>
              </div>

              <div class="col-md-8">
                <label class="form-label required" for="ServiceStreet1">Street Address</label>
                <input class="form-control" id="ServiceStreet1" name="ServiceStreet1" autocomplete="address-line1" required>
                <div class="invalid-feedback">Please enter the service address.</div>
              </div>

              <div class="col-md-4">
                <label class="form-label" for="ServiceStreet2">Address Line 2</label>
                <input class="form-control" id="ServiceStreet2" name="ServiceStreet2" autocomplete="address-line2">
              </div>

              <div class="col-md-5">
                <label class="form-label required" for="ServiceCity">City</label>
                <input class="form-control" id="ServiceCity" name="ServiceCity" autocomplete="address-level2" required>
                <div class="invalid-feedback">Please enter the service city.</div>
              </div>

              <div class="col-md-3">
                <label class="form-label required" for="ServiceState">State</label>
                <input class="form-control text-uppercase" id="ServiceState" name="ServiceState" maxlength="2" autocomplete="address-level1" required>
                <div class="invalid-feedback">Enter the 2-letter state code.</div>
              </div>

              <div class="col-md-4">
                <label class="form-label required" for="ServiceZip">ZIP</label>
                <input class="form-control zip-input" id="ServiceZip" name="ServiceZip" inputmode="numeric" maxlength="5" autocomplete="postal-code" required>
                <div class="invalid-feedback">Enter a 5-digit ZIP code.</div>
              </div>
            </div>

            <div class="col-md-6">
              <label class="form-label required" for="OnSiteContactName">On-Site Contact Name</label>
              <input class="form-control" id="OnSiteContactName" name="OnSiteContactName" autocomplete="name" required>
              <div class="invalid-feedback">Please enter the on-site contact name.</div>
            </div>

            <div class="col-md-6">
              <label class="form-label required" for="OnSiteContactPhone">On-Site Contact Phone</label>
              <input
                class="form-control phone-input"
                id="OnSiteContactPhone"
                name="OnSiteContactPhone"
                type="tel"
                inputmode="numeric"
                autocomplete="tel"
                maxlength="14"
                placeholder="3045551212"
                required
              >
              <div class="invalid-feedback">Enter a valid 10-digit US phone number.</div>
            </div>

            <div class="col-12">
              <label class="form-label required" for="IssueDescription">Describe the Issue</label>
              <textarea class="form-control" id="IssueDescription" name="IssueDescription" rows="5" required></textarea>
              <div class="invalid-feedback">Please describe the issue.</div>
            </div>

            <div class="col-12 pt-4">
              <h2 class="h5 mb-1">Billing Address</h2>
              <p class="text-muted small mb-0">This is where billing should be sent.</p>
            </div>

            <div class="col-12">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" id="BillingSameAsRequester" name="BillingSameAsRequester" value="Yes">
                <label class="form-check-label" for="BillingSameAsRequester">
                  Billing address is same as my address
                </label>
              </div>
            </div>

            <div id="billingAddressFields" class="row g-3">
              <div class="col-md-8">
                <label class="form-label required" for="BillingStreet1">Street Address</label>
                <input class="form-control" id="BillingStreet1" name="BillingStreet1" autocomplete="address-line1" required>
                <div class="invalid-feedback">Please enter the billing street address.</div>
              </div>

              <div class="col-md-4">
                <label class="form-label" for="BillingStreet2">Address Line 2</label>
                <input class="form-control" id="BillingStreet2" name="BillingStreet2" autocomplete="address-line2">
              </div>

              <div class="col-md-5">
                <label class="form-label required" for="BillingCity">City</label>
                <input class="form-control" id="BillingCity" name="BillingCity" autocomplete="address-level2" required>
                <div class="invalid-feedback">Please enter the billing city.</div>
              </div>

              <div class="col-md-3">
                <label class="form-label required" for="BillingState">State</label>
                <input class="form-control text-uppercase" id="BillingState" name="BillingState" maxlength="2" autocomplete="address-level1" required>
                <div class="invalid-feedback">Enter the 2-letter state code.</div>
              </div>

              <div class="col-md-4">
                <label class="form-label required" for="BillingZip">ZIP</label>
                <input class="form-control zip-input" id="BillingZip" name="BillingZip" inputmode="numeric" maxlength="5" autocomplete="postal-code" required>
                <div class="invalid-feedback">Enter a 5-digit ZIP code.</div>
              </div>
            </div>

            <div class="col-12 pt-2">
              <button type="submit" class="btn btn-brand btn-lg" id="submitBtn">Submit Request</button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</main>

<script>
  let requesterAutocomplete = null;
  let serviceAutocomplete = null;
  let billingAutocomplete = null;

  const form = document.getElementById("serviceRequestForm");
  const submitBtn = document.getElementById("submitBtn");
  const formMessage = document.getElementById("formMessage");

  const serviceSameAsRequester = document.getElementById("ServiceSameAsRequester");
  const serviceAddressFieldsWrap = document.getElementById("serviceAddressFields");

  const billingSameAsRequester = document.getElementById("BillingSameAsRequester");
  const billingAddressFieldsWrap = document.getElementById("billingAddressFields");

  const requesterAddressFields = {
    street1: document.getElementById("RequesterStreet1"),
    street2: document.getElementById("RequesterStreet2"),
    city: document.getElementById("RequesterCity"),
    state: document.getElementById("RequesterState"),
    zip: document.getElementById("RequesterZip")
  };

  const serviceAddressFields = {
    street1: document.getElementById("ServiceStreet1"),
    street2: document.getElementById("ServiceStreet2"),
    city: document.getElementById("ServiceCity"),
    state: document.getElementById("ServiceState"),
    zip: document.getElementById("ServiceZip")
  };

  const billingAddressFields = {
    street1: document.getElementById("BillingStreet1"),
    street2: document.getElementById("BillingStreet2"),
    city: document.getElementById("BillingCity"),
    state: document.getElementById("BillingState"),
    zip: document.getElementById("BillingZip")
  };

  function showMessage(message, kind) {
    formMessage.textContent = message;
    formMessage.classList.remove("d-none", "alert-danger", "alert-info", "alert-success");
    formMessage.classList.add(kind === "error" ? "alert-danger" : "alert-info");
  }

  function clearMessage() {
    formMessage.textContent = "";
    formMessage.classList.add("d-none");
    formMessage.classList.remove("alert-danger", "alert-info", "alert-success");
  }

  function digitsOnly(value) {
    return String(value || "").replace(/\D/g, "");
  }

  function normalizePhoneInput(input) {
    input.value = digitsOnly(input.value).slice(0, 11);
  }

  function normalizePhoneForSubmit(value) {
    let digits = digitsOnly(value);
    if (digits.length === 11 && digits.startsWith("1")) {
      digits = digits.slice(1);
    }
    return digits;
  }

  function normalizeZipInput(input) {
    input.value = digitsOnly(input.value).slice(0, 5);
  }

  function normalizeStateInput(input) {
    input.value = String(input.value || "").replace(/[^a-z]/gi, "").toUpperCase().slice(0, 2);
  }

  function buildAddress(street1, street2, city, state, zip) {
    const line1 = String(street1 || "").trim();
    const line2 = String(street2 || "").trim();
    const cityVal = String(city || "").trim();
    const stateVal = String(state || "").trim();
    const zipVal = String(zip || "").trim();

    const streetPart = [line1, line2].filter(Boolean).join(", ");
    const cityStateZipPart = [cityVal, stateVal, zipVal].filter(Boolean).join(", ");

    return [streetPart, cityStateZipPart].filter(Boolean).join(", ");
  }

  function setCombinedAddresses() {
    document.getElementById("RequesterAddress").value = buildAddress(
      requesterAddressFields.street1.value,
      requesterAddressFields.street2.value,
      requesterAddressFields.city.value,
      requesterAddressFields.state.value,
      requesterAddressFields.zip.value
    );

    document.getElementById("ServiceAddress").value = buildAddress(
      serviceAddressFields.street1.value,
      serviceAddressFields.street2.value,
      serviceAddressFields.city.value,
      serviceAddressFields.state.value,
      serviceAddressFields.zip.value
    );

    document.getElementById("BillingAddress").value = buildAddress(
      billingAddressFields.street1.value,
      billingAddressFields.street2.value,
      billingAddressFields.city.value,
      billingAddressFields.state.value,
      billingAddressFields.zip.value
    );
  }

  function copyAddressFields(source, target) {
    target.street1.value = source.street1.value;
    target.street2.value = source.street2.value;
    target.city.value = source.city.value;
    target.state.value = source.state.value;
    target.zip.value = source.zip.value;
    setCombinedAddresses();
  }

  function copyRequesterAddressToService() {
    copyAddressFields(requesterAddressFields, serviceAddressFields);
  }

  function copyRequesterAddressToBilling() {
    copyAddressFields(requesterAddressFields, billingAddressFields);
  }

  function toggleServiceAddressState() {
    const checked = serviceSameAsRequester.checked;

    if (checked) {
      copyRequesterAddressToService();
      serviceAddressFieldsWrap.classList.add("d-none");
      serviceAddressFields.street1.required = false;
      serviceAddressFields.city.required = false;
      serviceAddressFields.state.required = false;
      serviceAddressFields.zip.required = false;
    } else {
      serviceAddressFieldsWrap.classList.remove("d-none");
      serviceAddressFields.street1.required = true;
      serviceAddressFields.city.required = true;
      serviceAddressFields.state.required = true;
      serviceAddressFields.zip.required = true;
    }

    setCombinedAddresses();
  }

  function toggleBillingAddressState() {
    const checked = billingSameAsRequester.checked;

    if (checked) {
      copyRequesterAddressToBilling();
      billingAddressFieldsWrap.classList.add("d-none");
      billingAddressFields.street1.required = false;
      billingAddressFields.city.required = false;
      billingAddressFields.state.required = false;
      billingAddressFields.zip.required = false;
    } else {
      billingAddressFieldsWrap.classList.remove("d-none");
      billingAddressFields.street1.required = true;
      billingAddressFields.city.required = true;
      billingAddressFields.state.required = true;
      billingAddressFields.zip.required = true;
    }

    setCombinedAddresses();
  }

  function fillAddressFieldsFromPlace(prefix, place) {
    if (!place || !place.address_components) return;

    const street1El = document.getElementById(prefix + "Street1");
    const street2El = document.getElementById(prefix + "Street2");
    const cityEl = document.getElementById(prefix + "City");
    const stateEl = document.getElementById(prefix + "State");
    const zipEl = document.getElementById(prefix + "Zip");
    const fullEl = document.getElementById(prefix + "Address");

    let streetNumber = "";
    let route = "";
    let city = "";
    let state = "";
    let zip = "";

    for (const component of place.address_components) {
      const types = component.types || [];

      if (types.includes("street_number")) streetNumber = component.long_name;
      if (types.includes("route")) route = component.long_name;
      if (types.includes("locality")) city = component.long_name;
      if (types.includes("postal_town") && !city) city = component.long_name;
      if (types.includes("administrative_area_level_1")) state = component.short_name;
      if (types.includes("postal_code")) zip = component.long_name;
    }

    if (street1El) street1El.value = [streetNumber, route].filter(Boolean).join(" ").trim();
    if (cityEl) cityEl.value = city;
    if (stateEl) stateEl.value = state;
    if (zipEl) zipEl.value = zip;

    if (fullEl) {
      fullEl.value = buildAddress(
        street1El ? street1El.value : "",
        street2El ? street2El.value : "",
        cityEl ? cityEl.value : "",
        stateEl ? stateEl.value : "",
        zipEl ? zipEl.value : ""
      );
    }

    if (prefix === "Requester") {
      if (serviceSameAsRequester.checked) {
        copyRequesterAddressToService();
      }
      if (billingSameAsRequester.checked) {
        copyRequesterAddressToBilling();
      }
    }

    setCombinedAddresses();
  }

  function createAutocomplete(prefix) {
    const street1El = document.getElementById(prefix + "Street1");

    if (!street1El || !window.google || !google.maps || !google.maps.places) {
      return null;
    }

    const autocomplete = new google.maps.places.Autocomplete(street1El, {
      types: ["address"],
      componentRestrictions: { country: "us" },
      fields: ["address_components", "formatted_address"]
    });

    autocomplete.addListener("place_changed", function () {
      const place = autocomplete.getPlace();
      fillAddressFieldsFromPlace(prefix, place);
    });

    return autocomplete;
  }

  function initAddressAutocomplete() {
    requesterAutocomplete = createAutocomplete("Requester");
    serviceAutocomplete = createAutocomplete("Service");
    billingAutocomplete = createAutocomplete("Billing");
  }

  window.initAddressAutocomplete = initAddressAutocomplete;

  function addressLooksComplete(addressFields) {
    return !!(
      String(addressFields.street1.value || "").trim() &&
      String(addressFields.city.value || "").trim() &&
      String(addressFields.state.value || "").trim() &&
      digitsOnly(addressFields.zip.value).length === 5
    );
  }

  function clearCustomValidity() {
    document.querySelectorAll("input, select, textarea").forEach(function(el) {
      el.setCustomValidity("");
    });
  }

  function resetSubmitButton() {
    submitBtn.disabled = false;
    submitBtn.textContent = "Submit Request";
  }

  document.querySelectorAll(".phone-input").forEach(function(input) {
    input.addEventListener("input", function() {
      normalizePhoneInput(input);
    });
  });

  document.querySelectorAll(".zip-input").forEach(function(input) {
    input.addEventListener("input", function() {
      normalizeZipInput(input);
    });
  });

  ["RequesterState", "ServiceState", "BillingState"].forEach(function(id) {
    const input = document.getElementById(id);
    input.addEventListener("input", function() {
      normalizeStateInput(input);
    });
  });

  Object.values(requesterAddressFields).forEach(function(input) {
    input.addEventListener("input", function() {
      if (serviceSameAsRequester.checked) {
        copyRequesterAddressToService();
      }
      if (billingSameAsRequester.checked) {
        copyRequesterAddressToBilling();
      }
      setCombinedAddresses();
    });
  });

  Object.values(serviceAddressFields).forEach(function(input) {
    input.addEventListener("input", function() {
      setCombinedAddresses();
    });
  });

  Object.values(billingAddressFields).forEach(function(input) {
    input.addEventListener("input", function() {
      setCombinedAddresses();
    });
  });

  serviceSameAsRequester.addEventListener("change", function() {
    toggleServiceAddressState();
  });

  billingSameAsRequester.addEventListener("change", function() {
    toggleBillingAddressState();
  });

  form.addEventListener("submit", async function(e) {
    e.preventDefault();
    clearMessage();
    clearCustomValidity();

    document.querySelectorAll(".phone-input").forEach(function(input) {
      normalizePhoneInput(input);
    });

    document.querySelectorAll(".zip-input").forEach(function(input) {
      normalizeZipInput(input);
    });

    ["RequesterState", "ServiceState", "BillingState"].forEach(function(id) {
      normalizeStateInput(document.getElementById(id));
    });

    if (serviceSameAsRequester.checked) {
      copyRequesterAddressToService();
    }

    if (billingSameAsRequester.checked) {
      copyRequesterAddressToBilling();
    }

    const requesterPhone = document.getElementById("RequesterPhone");
    const onSitePhone = document.getElementById("OnSiteContactPhone");
    const requesterRelationship = document.getElementById("RequesterRelationship");
    const requesterEmail = document.getElementById("RequesterEmail");
    const textOk = document.getElementById("TextOK");
    const urgency = document.getElementById("Urgency");
    const propertyOccupied = document.getElementById("PropertyOccupied");
    const permissionToEnter = document.getElementById("PermissionToEnter");
    const onSiteContactName = document.getElementById("OnSiteContactName");

    requesterPhone.value = normalizePhoneForSubmit(requesterPhone.value);
    onSitePhone.value = normalizePhoneForSubmit(onSitePhone.value);

    if (requesterPhone.value.length !== 10) {
      requesterPhone.setCustomValidity("Enter a valid 10-digit US phone number, or 11 digits starting with 1.");
    }

    if (onSitePhone.value.length !== 10) {
      onSitePhone.setCustomValidity("Enter a valid 10-digit US phone number, or 11 digits starting with 1.");
    }

    if (!requesterRelationship.value) {
      requesterRelationship.setCustomValidity("Please select your relationship to the property.");
    }

    if (!requesterEmail.value.trim()) {
      requesterEmail.setCustomValidity("Enter a valid email address.");
    }

    if (!textOk.value) {
      textOk.setCustomValidity("Please select Yes or No.");
    }

    if (!urgency.value) {
      urgency.setCustomValidity("Please select urgency.");
    }

    if (!propertyOccupied.value) {
      propertyOccupied.setCustomValidity("Please select property occupied status.");
    }

    if (!permissionToEnter.value) {
      permissionToEnter.setCustomValidity("Please select permission to enter.");
    }

    if (!onSiteContactName.value.trim()) {
      onSiteContactName.setCustomValidity("Please enter the on-site contact name.");
    }

    const requesterZip = document.getElementById("RequesterZip");
    const serviceZip = document.getElementById("ServiceZip");
    const billingZip = document.getElementById("BillingZip");

    if (digitsOnly(requesterZip.value).length !== 5) {
      requesterZip.setCustomValidity("Enter a 5-digit ZIP code.");
    }

    if (!serviceSameAsRequester.checked && digitsOnly(serviceZip.value).length !== 5) {
      serviceZip.setCustomValidity("Enter a 5-digit ZIP code.");
    }

    if (!billingSameAsRequester.checked && digitsOnly(billingZip.value).length !== 5) {
      billingZip.setCustomValidity("Enter a 5-digit ZIP code.");
    }

    setCombinedAddresses();

    if (!addressLooksComplete(requesterAddressFields)) {
      requesterAddressFields.street1.setCustomValidity("Please select or complete a valid requester address.");
    }

    if (!serviceSameAsRequester.checked && !addressLooksComplete(serviceAddressFields)) {
      serviceAddressFields.street1.setCustomValidity("Please select or complete a valid service address.");
    }

    if (!billingSameAsRequester.checked && !addressLooksComplete(billingAddressFields)) {
      billingAddressFields.street1.setCustomValidity("Please select or complete a valid billing address.");
    }

    if (!form.checkValidity()) {
      form.classList.add("was-validated");
      resetSubmitButton();
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = "Submitting...";
    showMessage("Submitting your request...", "info");

    try {
      const formData = new FormData(form);

      const response = await fetch(form.action, {
        method: "POST",
        body: formData
      });

      const text = (await response.text()).trim();

      if (!response.ok) {
        throw new Error("Request failed with HTTP " + response.status + ".");
      }

      if (text === "OK") {
        window.location.href = "/request-confirmation.html";
        return;
      }

      if (text.startsWith("ERROR:")) {
        throw new Error(text.replace(/^ERROR:\s*/, "").trim() || "Submission failed.");
      }

      throw new Error("Unexpected response from server.");
    } catch (error) {
      showMessage(
        error && error.message ? error.message : "Unable to submit request right now.",
        "error"
      );
      resetSubmitButton();
    }
  });

  toggleServiceAddressState();
  toggleBillingAddressState();
  setCombinedAddresses();
</script>

