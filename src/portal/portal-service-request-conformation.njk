---
layout: layouts/base.njk
title: Ketter Home Improvements | Service Request Submitted
permalink: /portal/portal-service-request-confirmation/index.html
headerMode: portalInner
---

<div class="portal-page">
  <section class="portal-hero portal-hero-success">
    <div class="portal-hero-icon" aria-hidden="true">✓</div>
    <div class="portal-hero-copy">
      <h1>Service Request Submitted</h1>
      <p>Your service request was submitted successfully. We will review it as quickly as possible.</p>
    </div>
  </section>

  <section class="portal-card portal-card-narrow">
    <div class="confirmation-actions">
      <a id="returnToPortalBtn" class="btn btn-brand" href="/portal/">Return to Project Center</a>
      <a id="submitAnotherBtn" class="btn btn-outline-brand" href="/portal/portal-service-request/">Submit Another Request</a>
    </div>
  </section>
</div>

<script>
  (function () {
    const params = new URLSearchParams(window.location.search);
    const token = (params.get("t") || "").trim();

    if (!token) return;

    const returnBtn = document.getElementById("returnToPortalBtn");
    const anotherBtn = document.getElementById("submitAnotherBtn");

    if (returnBtn) {
      returnBtn.href = "/portal/?t=" + encodeURIComponent(token);
    }

    if (anotherBtn) {
      anotherBtn.href = "/portal/portal-service-request/?t=" + encodeURIComponent(token);
    }
  })();
</script>