---
layout: layouts/base.njk
title: Ketter Home Improvements | Project Center
permalink: /portal/index.html
headerMode: portalHome
---

<main class="page-wrap">
  <div class="site-shell">
    <div class="content-shell">
      <div class="card-block">
        <div class="card-block-body">
          <div id="portal-body" class="text-muted">Please wait.</div>
        </div>
      </div>

      <div class="portal-footer-nav">
        <a class="portal-menu-link" id="portal-menu-link" href="#">
          <div class="card-block">
            <div class="card-block-body">
              <p class="portal-menu-title">Project Center Menu</p>
              <p class="portal-menu-text">Browse all project views and reporting options.</p>
            </div>
          </div>
        </a>

        <button class="portal-menu-button" id="portal-logout-button" type="button">
          <div class="card-block">
            <div class="card-block-body">
              <p class="portal-menu-title">Log Out</p>
              <p class="portal-menu-text">End access now and require a new secure link next time.</p>
            </div>
          </div>
        </button>
      </div>
    </div>
  </div>
</main>

<script>
  const PORTAL_API_URL = "https://script.google.com/macros/s/AKfycby12TuuhZaJjy6_xWtbKfH3R6joBD22RpeoANAU6EPBokz7IrIAq8v022EQAVdclu-D3w/exec";

  function getToken() {
    const params = new URLSearchParams(window.location.search);
    return (params.get("t") || "").trim();
  }

  function setFooterMenuLink(token) {
    const link = document.getElementById("portal-menu-link");
    if (!link) return;

    if (token) {
      link.href = "/portal/menu/?t=" + encodeURIComponent(token);
    } else {
      link.href = "#";
    }
  }

  function setLogoutAction(token) {
    const button = document.getElementById("portal-logout-button");
    if (!button) return;

    button.disabled = !token;

    button.addEventListener("click", async function() {
      if (!token) {
        window.location.href = "https://ketter.us/portal/sign-in/";
        return;
      }

      const confirmed = window.confirm("Log out of Project Center?");
      if (!confirmed) return;

      try {
        button.disabled = true;
        const url = PORTAL_API_URL + "?mode=logout&t=" + encodeURIComponent(token);
        await fetch(url, { method: "GET" });
      } catch (error) {
      }

      window.location.href = "https://ketter.us/portal/sign-in/";
    });
  }

  async function loadPortal() {
    const bodyEl = document.getElementById("portal-body");
    const token = getToken();

    setFooterMenuLink(token);
    setLogoutAction(token);

    if (!token) {
      bodyEl.innerHTML = '<p class="text-danger mb-0">This link is missing an access token.</p>';
      return;
    }

    try {
      const url = PORTAL_API_URL + "?t=" + encodeURIComponent(token);
      const response = await fetch(url, { method: "GET" });
      const data = await response.json();

      if (!data.success) {
        bodyEl.innerHTML = '<p class="text-danger mb-0">' + escapeHtml(data.message || "Access failed.") + '</p>';
        return;
      }

      const projects = (data.data && Array.isArray(data.data.projects)) ? data.data.projects : [];
      const statusSummary = summarizeStatuses(projects);

      bodyEl.innerHTML = `
        <p class="mb-2">Welcome, <strong>${escapeHtml((data.client && data.client.clientName) || "Client")}</strong>.</p>
        <p class="text-muted mb-0">Select a project to open its report.</p>
        ${renderStatusSummary(statusSummary)}
        ${renderProjects(projects, token)}
      `;
    } catch (error) {
      bodyEl.innerHTML = '<p class="text-danger mb-0">Unable to load Project Center right now.</p>';
    }
  }

  function summarizeStatuses(projects) {
    const summary = {
      total: projects.length,
      active: 0,
      new: 0,
      other: 0
    };

    projects.forEach(project => {
      const status = String(project.status || "").trim().toLowerCase();

      if (status === "active") {
        summary.active += 1;
      } else if (status === "new") {
        summary.new += 1;
      } else {
        summary.other += 1;
      }
    });

    return summary;
  }

  function renderStatusSummary(summary) {
    return `
      <div class="summary-grid">
        <div class="summary-card">
          <p class="summary-label">Total Projects</p>
          <p class="summary-value">${escapeHtml(String(summary.total))}</p>
        </div>
        <div class="summary-card">
          <p class="summary-label">Active</p>
          <p class="summary-value">${escapeHtml(String(summary.active))}</p>
        </div>
        <div class="summary-card">
          <p class="summary-label">New</p>
          <p class="summary-value">${escapeHtml(String(summary.new))}</p>
        </div>
        <div class="summary-card">
          <p class="summary-label">Other</p>
          <p class="summary-value">${escapeHtml(String(summary.other))}</p>
        </div>
      </div>
    `;
  }

  function renderProjects(projects, token) {
    if (!projects.length) {
      return '<p class="text-muted mt-3 mb-0">No projects have been shared to your Project Center yet.</p>';
    }

    return `
      <div class="project-list">
        ${projects.map(project => `
          <a class="project-card-link" href="/portal/report/?t=${encodeURIComponent(token)}&p=${encodeURIComponent(project.projectId || "")}">
            <div class="project-item">
              <div class="project-top">
                <p class="project-name">${escapeHtml(project.projectName || "Unnamed Project")}</p>
                <p class="project-status">Status: ${escapeHtml(project.status || "Not set")}</p>
              </div>
            </div>
          </a>
        `).join("")}
      </div>
    `;
  }

  function escapeHtml(value) {
    return String(value || "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#39;");
  }

  loadPortal();
</script>