<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Project Center Sign In</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="/assets/css/main.css">
</head>
<body>
  <div class="portal-v2-shell portal-v2-page">
    <div class="portal-v2-content portal-v2-stack">
      <section class="portal-v2-card">
        <div class="portal-v2-card-header">
          <h1 class="portal-v2-card-title">Project Center Sign In</h1>
          <p class="portal-v2-card-subtitle">
            Enter the email address and ZIP code associated with your account. If we find a matching Project Center account, we will send a secure access link to your email.
          </p>
        </div>

        <div class="portal-v2-card-body">
          <form id="portalLookupForm" novalidate>
            <div class="row g-3">
              <div class="col-md-8">
                <label class="form-label required" for="lookupEmail">Email</label>
                <input
                  class="form-control"
                  id="lookupEmail"
                  name="lookupEmail"
                  type="email"
                  autocomplete="email"
                  required
                >
                <div class="invalid-feedback">Enter a valid email address.</div>
              </div>

              <div class="col-md-4">
                <label class="form-label required" for="lookupZip">ZIP</label>
                <input
                  class="form-control"
                  id="lookupZip"
                  name="lookupZip"
                  inputmode="numeric"
                  maxlength="5"
                  autocomplete="postal-code"
                  required
                >
                <div class="invalid-feedback">Enter a 5-digit ZIP code.</div>
              </div>

              <div class="col-12 pt-2">
                <button type="submit" class="btn btn-brand" id="lookupSubmitBtn">Send Secure Link</button>
              </div>
            </div>
          </form>
        </div>
      </section>

      <section id="portalStatusCard" class="portal-v2-card portal-hidden">
        <div class="portal-v2-card-header">
          <h2 class="portal-v2-card-title">Status</h2>
        </div>
        <div class="portal-v2-card-body">
          <p id="portalStatusMessage" class="portal-v2-empty">Please wait.</p>
        </div>
      </section>
    </div>
  </div>

  <script>
    const PORTAL_LOOKUP_API_URL = "https://script.google.com/macros/s/AKfycbz58ThqBCcjZ5hLAbJrkRL6OQj4rKJPGMm5wrmui1JkdmwGEPrBKSAqTFpBP_685Zij/exec";

    const form = document.getElementById("portalLookupForm");
    const emailInput = document.getElementById("lookupEmail");
    const zipInput = document.getElementById("lookupZip");
    const submitBtn = document.getElementById("lookupSubmitBtn");

    const statusCard = document.getElementById("portalStatusCard");
    const statusMessage = document.getElementById("portalStatusMessage");

    function digitsOnly(value) {
      return String(value || "").replace(/\D/g, "");
    }

    function normalizeZipInput() {
      zipInput.value = digitsOnly(zipInput.value).slice(0, 5);
    }

    function showStatus(message, isError = false) {
      statusCard.classList.remove("portal-hidden");
      statusMessage.textContent = message;
      statusMessage.className = isError ? "text-danger mb-0" : "portal-v2-empty mb-0";
    }

    function hideStatus() {
      statusCard.classList.add("portal-hidden");
      statusMessage.textContent = "";
      statusMessage.className = "portal-v2-empty mb-0";
    }

    async function submitLookup(event) {
      event.preventDefault();

      normalizeZipInput();
      hideStatus();

      form.classList.remove("was-validated");
      emailInput.setCustomValidity("");
      zipInput.setCustomValidity("");

      if (digitsOnly(zipInput.value).length !== 5) {
        zipInput.setCustomValidity("Enter a 5-digit ZIP code.");
      }

      if (!form.checkValidity()) {
        form.classList.add("was-validated");
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = "Sending...";

      showStatus("Please wait...");

      try {
        const requestUrl =
          PORTAL_LOOKUP_API_URL +
          "?mode=lookup" +
          "&email=" + encodeURIComponent(String(emailInput.value || "").trim()) +
          "&zip=" + encodeURIComponent(digitsOnly(zipInput.value));

        const response = await fetch(requestUrl, { method: "GET" });
        const responseText = await response.text();

        let data;
        try {
          data = JSON.parse(responseText);
        } catch (parseError) {
          throw new Error("HTTP " + response.status + " | " + responseText);
        }

        if (!data.success) {
          showStatus(data.message || "Unable to complete request right now.", true);
          return;
        }

        showStatus(
          data.message || "If we found a matching Project Center account, we sent a secure access link to your email."
        );
      } catch (error) {
        showStatus(
          String(error && error.message ? error.message : error) || "Unable to complete request right now.",
          true
        );
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = "Send Secure Link";
      }
    }

    zipInput.addEventListener("input", normalizeZipInput);
    form.addEventListener("submit", submitLookup);
  </script>
</body>
</html>