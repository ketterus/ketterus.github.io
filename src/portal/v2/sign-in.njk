---
layout: false
permalink: /portal/v2/sign-in/index.html
---

<main class="page-wrap">
  <div class="site-shell">
    <div class="content-shell">
      <div class="card-block portal-card">
        <div class="card-block-body">
          <div class="mb-4">
            <h1 class="h2 mb-2">Project Center Sign In</h1>
            <p class="text-muted mb-0">Enter the email address and ZIP code associated with your account. If we find a matching Project Center account, we will send a secure access link to your email.</p>
          </div>

          <form id="portalLookupForm" novalidate>
            <div class="row g-3">
              <div class="col-md-8">
                <label class="form-label required" for="lookupEmail">Email</label>
                <input
                  class="form-control"
                  id="lookupEmail"
                  name="lookupEmail"
                  type="email"
                  autocomplete="email"
                  required
                >
                <div class="invalid-feedback">Enter a valid email address.</div>
              </div>

              <div class="col-md-4">
                <label class="form-label required" for="lookupZip">ZIP</label>
                <input
                  class="form-control"
                  id="lookupZip"
                  name="lookupZip"
                  inputmode="numeric"
                  maxlength="5"
                  autocomplete="postal-code"
                  required
                >
                <div class="invalid-feedback">Enter a 5-digit ZIP code.</div>
              </div>

              <div class="col-12 pt-2">
                <button type="submit" class="btn btn-brand btn-lg" id="lookupSubmitBtn">Send Secure Link</button>
              </div>
            </div>
          </form>
        </div>
      </div>

      <div id="portalStatusCard" class="card-block portal-card portal-hidden mt-3">
        <div class="card-block-body">
          <h2 class="h5 mb-3">Status</h2>
          <div id="portalStatusMessage" class="text-muted">Please wait.</div>
        </div>
      </div>
    </div>
  </div>
</main>

<script>
  const PORTAL_LOOKUP_API_URL = "https://script.google.com/macros/s/AKfycbz58ThqBCcjZ5hLAbJrkRL6OQj4rKJPGMm5wrmui1JkdmwGEPrBKSAqTFpBP_685Zij/exec";

  const form = document.getElementById("portalLookupForm");
  const emailInput = document.getElementById("lookupEmail");
  const zipInput = document.getElementById("lookupZip");
  const submitBtn = document.getElementById("lookupSubmitBtn");

  const statusCard = document.getElementById("portalStatusCard");
  const statusMessage = document.getElementById("portalStatusMessage");

  function digitsOnly(value) {
    return String(value || "").replace(/\D/g, "");
  }

  function normalizeZipInput() {
    zipInput.value = digitsOnly(zipInput.value).slice(0, 5);
  }

  function showStatus(message, isError = false) {
    statusCard.classList.remove("portal-hidden");
    statusMessage.textContent = message;
    statusMessage.className = isError ? "text-danger" : "text-muted";
  }

  function hideStatus() {
    statusCard.classList.add("portal-hidden");
    statusMessage.textContent = "";
    statusMessage.className = "text-muted";
  }

  async function submitLookup(event) {
    event.preventDefault();

    normalizeZipInput();
    hideStatus();

    form.classList.remove("was-validated");
    emailInput.setCustomValidity("");
    zipInput.setCustomValidity("");

    if (digitsOnly(zipInput.value).length !== 5) {
      zipInput.setCustomValidity("Enter a 5-digit ZIP code.");
    }

    if (!form.checkValidity()) {
      form.classList.add("was-validated");
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = "Sending...";

    showStatus("Please wait...");

    try {
      const formData = new URLSearchParams();
      formData.set("mode", "lookup");
      formData.set("email", String(emailInput.value || "").trim());
      formData.set("zip", digitsOnly(zipInput.value));

      const response = await fetch(PORTAL_LOOKUP_API_URL, {
        method: "POST",
        headers: {
          "Content-Type": "application/x-www-form-urlencoded;charset=UTF-8"
        },
        body: formData.toString()
      });

      const responseText = await response.text();

      let data;
      try {
        data = JSON.parse(responseText);
      } catch (parseError) {
        throw new Error("HTTP " + response.status + " | " + responseText);
      }

      if (!data.success) {
        showStatus(data.message || "Unable to complete request right now.", true);
        return;
      }

      showStatus(
        data.message || "If we found a matching Project Center account, we sent a secure access link to your email."
      );
    } catch (error) {
      showStatus(String(error && error.message ? error.message : error), true);
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = "Send Secure Link";
    }
  }

  zipInput.addEventListener("input", normalizeZipInput);
  form.addEventListener("submit", submitLookup);
</script>